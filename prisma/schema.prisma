generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  TECHNICIAN
}

enum EquipmentType {
  NOTEBOOK
  DESKTOP
  OTHER
}

enum ServiceOrderStatus {
  RECEIVED
  IN_DIAGNOSIS
  WAITING_FOR_APPROVAL
  APPROVED
  IN_REPAIR
  FINAL_TESTING
  READY_FOR_PICKUP
  COMPLETED
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
}

model Organization {
  id            String                 @id @default(cuid())
  name          String
  slug          String                 @unique
  users         User[]
  customers     Customer[]
  equipment     Equipment[]
  serviceOrders ServiceOrder[]
  diagnostics   Diagnostic[]
  quotes        Quote[]
  quoteItems    QuoteItem[]
  timeline      ServiceOrderTimeline[]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
}

model User {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  sessions       AuthSession[]
  name           String
  email          String        @unique
  passwordHash   String
  role           UserRole      @default(TECHNICIAN)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([id, organizationId])
  @@index([organizationId])
}

model AuthSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model Customer {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  name           String
  email          String?
  phone          String
  document       String?
  equipment      Equipment[]
  serviceOrders  ServiceOrder[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([id, organizationId])
  @@index([organizationId])
  @@index([organizationId, name])
}

model Equipment {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  customerId     String
  customer       Customer       @relation(fields: [customerId, organizationId], references: [id, organizationId], onDelete: Restrict)
  serviceOrders  ServiceOrder[]
  type           EquipmentType
  brand          String
  model          String
  serialNumber   String?
  accessories    String?        @db.Text
  notes          String?        @db.Text
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([id, organizationId])
  @@unique([organizationId, serialNumber])
  @@index([organizationId])
  @@index([organizationId, customerId])
}

model ServiceOrder {
  id             String                 @id @default(cuid())
  organizationId String
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  customerId     String
  customer       Customer               @relation(fields: [customerId, organizationId], references: [id, organizationId], onDelete: Restrict)
  equipmentId    String
  equipment      Equipment              @relation(fields: [equipmentId, organizationId], references: [id, organizationId], onDelete: Restrict)
  diagnostic     Diagnostic?
  quotes         Quote[]
  timeline       ServiceOrderTimeline[]
  publicCode     String                 @unique
  reportedIssue  String                 @db.Text
  status         ServiceOrderStatus     @default(RECEIVED)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@unique([id, organizationId])
  @@index([organizationId])
  @@index([organizationId, customerId])
  @@index([organizationId, equipmentId])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
}

model Diagnostic {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  serviceOrderId String
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId, organizationId], references: [id, organizationId], onDelete: Restrict)
  description    String       @db.Text
  technicalNotes String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([id, organizationId])
  @@unique([serviceOrderId, organizationId])
  @@index([organizationId])
}

model Quote {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  serviceOrderId String
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId, organizationId], references: [id, organizationId], onDelete: Restrict)
  items          QuoteItem[]
  status         QuoteStatus  @default(DRAFT)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([id, organizationId])
  @@index([organizationId])
  @@index([organizationId, serviceOrderId])
  @@index([organizationId, status])
}

model QuoteItem {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  quoteId        String
  quote          Quote        @relation(fields: [quoteId, organizationId], references: [id, organizationId], onDelete: Cascade)
  description    String
  quantity       Int
  unitPrice      Decimal      @db.Decimal(12, 2)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([id, organizationId])
  @@index([organizationId])
  @@index([organizationId, quoteId])
}

model ServiceOrderTimeline {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  serviceOrderId String
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId, organizationId], references: [id, organizationId], onDelete: Restrict)
  type           String
  description    String       @db.Text
  createdAt      DateTime     @default(now())

  @@unique([id, organizationId])
  @@index([organizationId])
  @@index([organizationId, serviceOrderId, createdAt])
}
